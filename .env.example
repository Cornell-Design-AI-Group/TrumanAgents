# =============================================================================
# Truman Agents — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Lines starting with # are comments. All values below are examples.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# MongoDB connection string. For local development, use:
MONGODB_URI=mongodb://localhost:27017/truman

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# Port the app listens on (default: 3000)
PORT=3000

# Secret used to sign session cookies. Change this to a random string.
SESSION_SECRET=change-me-to-a-random-string

# Identifies the active study session. Used by the grader and level management.
SESSION_NAME=my-study-session-1

# -----------------------------------------------------------------------------
# OpenAI (required for LLM agent features)
# -----------------------------------------------------------------------------

# Your OpenAI API key. Required for agent chat responses and action grading.
OPENAI_API_KEY=sk-your-key-here

# Which OpenAI model to use (default: gpt-4o-mini)
OPENAI_API_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Site Branding
# -----------------------------------------------------------------------------

# The name displayed in the browser tab and header
SITE_NAME=My Simulation

# Path to the site logo (served from the public/ folder)
SITE_LOGO=/public/logo.png

# Path to the site favicon
SITE_FAVICON=/public/favicon.ico

# Path to the homepage background image
SITE_PICTURE=/public/homepage.jpg

# -----------------------------------------------------------------------------
# Participant Setup
# -----------------------------------------------------------------------------

# Label shown on the signup form for the participant ID field.
# Examples: "Mechanical Turk ID", "Prolific ID", "Participant ID"
IDENTIFIER=Participant ID

# Email displayed to participants for researcher contact
RESEARCHER_EMAIL=your-email@university.edu

# Link to a post-study survey (e.g., Qualtrics). Leave empty if not using one.
POST_SURVEY=
POST_SURVEY_WITH_QUALTRICS=FALSE

# -----------------------------------------------------------------------------
# Experimental Design
# -----------------------------------------------------------------------------

# Number of experimental conditions participants are randomly assigned to
NUM_EXP_CONDITIONS=1

# Comma-separated names for each condition (must match NUM_EXP_CONDITIONS)
EXP_CONDITIONS_NAMES=control

# Number of simulated "days" in the feed timeline
NUM_DAYS=1

# Feed ordering: CHRONOLOGICAL, NEWEST, or SHUFFLE
FEED_ORDER=CHRONOLOGICAL

# Whether flagged content is removed from the feed (TRUE/FALSE)
REMOVE_FLAGGED_CONTENT=FALSE

# -----------------------------------------------------------------------------
# CDN (optional)
# -----------------------------------------------------------------------------

# If you serve images (post pictures, profile pictures) from a CDN, set the
# base URL here. If left empty, images are served locally from the public/ folder.
CDN=
